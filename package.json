{
  "name": "yaneyuka-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "clean": "powershell -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue }; exit 0\"",
    "clean:firebase": "rimraf .firebase || echo Firebase directory cleanup skipped",
    "predeploy": "npm run clean && npm run clean:firebase",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "export": "npm run clean && next build",
    "deploy": "npm run predeploy && npx firebase-tools deploy",
    "deploy:preview": "npm run export && npx firebase-tools hosting:channel:deploy yane-preview --expires 7d"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@heroicons/react": "^2.2.0",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.19",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/youtube": "0.1.2",
    "@types/youtube-player": "5.5.11",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "exifr": "^7.1.3",
    "firebase": "^10.12.5",
    "firebase-admin": "^13.8.0",
    "html-docx-js": "^0.3.1",
    "html-to-docx": "^1.8.0",
    "html2pdf.js": "^0.12.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "material-icons": "^1.13.14",
    "next": "^16.0.10",
    "nodemailer": "^6.9.16",
    "pdf-compressor": "^1.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168",
    "react": "^19.2.3",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-youtube": "10.1.0",
    "screenfull": "^6.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "firebase-tools": "^14.26.0",
    "postcss": "^8",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
